<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!--
        Console appender — all logs go to stdout during development.
        In production you'd add a RollingFileAppender here.
    -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <!--
                Pattern breakdown:
                  %d{HH:mm:ss.SSS}  — timestamp (hour:min:sec.millis)
                  %-5level          — log level, left-padded to 5 chars (DEBUG, INFO, WARN, ERROR)
                  [%thread]         — thread name — critical for a multi-threaded server,
                                      shows you which ClientHandler thread is logging
                  %logger{36}       — logger name (class name), truncated to 36 chars
                  %msg%n            — the actual message + newline
            -->
            <pattern>%d{HH:mm:ss.SSS} %-5level [%thread] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!--
        Root logger level: INFO for production.
        DEBUG inside hot paths (ClientHandler read loop) adds measurable latency
        and floods Railway's 500 logs/sec limit.
    -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>

    <!-- Suppress noisy Spring Boot / Tomcat internals -->
    <logger name="org.springframework" level="WARN"/>
    <logger name="org.apache.catalina" level="WARN"/>
    <logger name="org.apache.tomcat" level="WARN"/>
    <logger name="org.apache.coyote" level="WARN"/>

</configuration>
